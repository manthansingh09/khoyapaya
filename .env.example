# Copy this file to ".env" and fill in your values, then run the app.
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows cmd)
# The .env file is git-ignored and must NOT be committed.

# Enables the AI free-form report extraction (🗣️ Describe freely).
# Get a key at https://console.anthropic.com/ . Leave blank to use the
# offline keyword fallback instead.
ANTHROPIC_API_KEY=

# Signs the staff-login session cookie. Use any long random string.
# Only needed for the Flask server (app/server.py) and Vercel.
FLASK_SECRET=change-me-to-a-long-random-string
